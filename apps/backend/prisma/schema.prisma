generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  image_url   String?  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  sales Sale[]

  @@map("products")
}

model Sale {
  id              String   @id @default(cuid())
  product_id      String   
  starts_at       DateTime 
  ends_at         DateTime 
  total_stock     Int      
  remaining_stock Int      
  created_at      DateTime @default(now()) 
  updated_at      DateTime @updatedAt 

  product Product @relation(fields: [product_id], references: [id])
  orders  Order[]

  @@map("sales")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  created_at  DateTime @default(now()) 

  orders Order[]

  @@map("users")
}

enum OrderStatus {
  CONFIRMED
}

model Order {
  id              String      @id @default(cuid())
  user_id         String      
  sale_id         String      
  idempotency_key String      @unique 
  status          OrderStatus @default(CONFIRMED)
  created_at      DateTime    @default(now()) 
  updated_at      DateTime    @updatedAt

  user User @relation(fields: [user_id], references: [id])
  sale Sale @relation(fields: [sale_id], references: [id])

  @@unique([user_id, sale_id], map: "uq_orders_user_sale") // 1 user can only buy 1 product on each sale
  @@map("orders")
}
